---
import FloatingCanvas from '../components/FloatingCanvas.astro';
import Preloader from '../components/Preloader.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  type?: string;
}

const {
  title = 'Plane View Collective',
  description = 'Clarity, created with people in mind.',
  image = '/logo/plane-view-logo.png',
  url = 'https://www.planeview.co.za',
  type = 'website'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://www.planeview.co.za');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Basic Meta -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Canonical URL — prevents duplicate content penalties -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Robots — tells Google to index and follow all links -->
  <meta name="robots" content="index, follow" />

  <!-- Author & Brand -->
  <meta name="author" content="Plane View Collective" />
  <meta name="copyright" content="Plane View Collective" />

  <!-- Geo targeting — helps with local Cape Town SEO -->
  <meta name="geo.region" content="ZA-WC" />
  <meta name="geo.placename" content="Cape Town" />
  <meta name="geo.position" content="-33.9249;18.4241" />
  <meta name="ICBM" content="-33.9249, 18.4241" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />

  <!-- SEO / OpenGraph -->
  <meta property="og:site_name" content="Plane View Collective" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={image} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Plane View Collective — Cape Town Marketing & Design Agency" />
  <meta property="og:locale" content="en_ZA" />



  <!-- Theme -->
  <meta name="theme-color" content="#111111" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <!-- PWA -->
  <link rel="manifest" href="/site.webmanifest" />

  <ViewTransitions />

  <!-- Page-specific head injection (schema, etc.) -->
  <slot name="head" />
</head>

<body>
  <Preloader />

  <div class="page-wrapper">
    <FloatingCanvas />
    <div class="page-content">
      <slot />
    </div>
  </div>
</body>

<style is:global>
@import '../styles/global.css';

.page-wrapper {
  position: relative;
  width: 100%;
  min-height: 100vh;
}

.page-content {
  position: relative;
  z-index: 1;
}
</style>